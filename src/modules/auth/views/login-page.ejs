<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login Admin SajakVisual.</title>
    <!-- Favicon-->
    <link rel="icon" type="image/webp" href="/img/favicon.webp" />
    <!-- Import Font Nunito -->
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Import CSS -->
    <link rel="stylesheet" href="/css/admin-login.css" />
    <link rel="stylesheet" href="/css/notification.css" />
  </head>
  <body>
    <div class="split-layout">
      <!-- Left side: Image Slider -->
      <div class="slider-section">
        <div class="slide active" style="background-image: url('/img/image1.webp')"></div>
        <div class="slide" style="background-image: url('/img/image2.webp')"></div>
        <div class="slide" style="background-image: url('/img/image3.webp')"></div>
        <div class="slide" style="background-image: url('/img/image4.webp')"></div>
        <div class="slide" style="background-image: url('/img/image5.webp')"></div>
        <div class="slider-overlay"></div>

        <div class="slider-content">
          <img src="/img/logo_sajakvisual.webp" alt="SajakVisual Logo" class="slider-logo" />
          <p>"Platform undangan digital elegan dan modern untuk menyempurnakan momen berharga."</p>
        </div>
      </div>

      <!-- Right side: Login Form -->
      <div class="form-section">
        <!-- Theme Toggle Button -->
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme">
          <i class="ph ph-moon"></i>
        </button>

        <div class="login-container">
          <div class="login-header">
            <h2>Masuk Sebagai Admin</h2>
            <p>Masukkan email dan password untuk melanjutkan.</p>
          </div>

          <form id="admin-login-form">
            <div class="form-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                class="form-control"
                placeholder="admin@sajakvisual.com"
                required
                autocomplete="email"
              />
            </div>

            <div class="form-group">
              <label for="password">Password</label>
              <input
                type="password"
                id="password"
                class="form-control"
                placeholder="Masukkan password Anda"
                required
                autocomplete="current-password"
              />
            </div>

            <button type="submit" id="submit-btn" class="btn-primary">Masuk</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Import Javascript -->
    <script src="/javascript/notification.js"></script>
    <script src="/javascript/admin-login.js"></script>
  </body>
</html>
