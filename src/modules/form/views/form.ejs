<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
    />
    <title>Isi Data Undangan - Sajak Visual</title>

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="/img/favicon.webp" />

    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/main-website.css" />
    <link rel="stylesheet" href="/css/form.css" />
    <link rel="stylesheet" href="/css/modal.css" />
  </head>
  <body>
    <div class="form-wrapper">
      <header class="form-header reveal-on-scroll">
        <div class="header-text">
          <h1 class="form-title">Edit Data Undangan</h1>
          <p class="form-subtitle">Sesuaikan detail undangan digital Anda di sini.</p>
        </div>
        
        <!-- Theme Toggle -->
        <button
          class="theme-toggle-btn form-theme-toggle"
          aria-label="Toggle Dark Mode"
          id="theme-toggle"
        >
          <i class="ph ph-moon"></i>
        </button>
      </header>

      <form id="invitation-form" class="invitation-form">
        <!-- Block 1: Pengaturan Utama -->
        <section class="form-section reveal-on-scroll" style="transition-delay: 100ms">
          <div class="section-header">
            <h2 class="section-title">Pengaturan Utama</h2>
          </div>
          <div class="section-body">

            <div class="input-group">
              <label for="countdown_target">Tanggal & Waktu Hitung Mundur (Countdown)</label>
              <div class="input-wrapper">
                <i class="ph ph-calendar-blank input-icon"></i>
                <input
                  type="datetime-local"
                  id="countdown_target"
                  name="countdown_target"
                  class="form-input"
                  required
                />
              </div>
            </div>

            <div class="input-group" style="margin-top: 16px;">
              <label>Unggah Foto Cover Prewedding</label>
              <div class="input-wrapper">
                <i class="ph ph-camera input-icon" style="z-index: 1;"></i>
                <input
                  type="file"
                  id="foto_cover"
                  name="foto_cover"
                  accept="image/*"
                  class="form-file-hidden"
                  required
                />
                <label for="foto_cover" class="form-input file-upload-label">
                  <span class="file-btn">Pilih Gambar</span>
                  <span class="file-name">Belum ada gambar</span>
                </label>
              </div>
            </div>


          </div>
        </section>

        <!-- Block 2: Data Mempelai Pria -->
        <section
          class="form-section reveal-on-scroll"
          id="mempelai-pria-section"
          style="transition-delay: 200ms"
        >
          <div class="section-header">
            <h2 class="section-title">Data Mempelai Pria</h2>
          </div>
          <div class="section-body">
            <div class="input-group">
              <label for="pria_nama_lengkap">Nama Lengkap</label>
              <div class="input-wrapper">
                <i class="ph ph-user input-icon"></i>
                <input
                  type="text"
                  id="pria_nama_lengkap"
                  name="pria_nama_lengkap"
                  class="form-input"
                  placeholder="contoh: Romeo Montague, S.T."
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="pria_nama_panggilan">Nama Panggilan</label>
              <div class="input-wrapper">
                <i class="ph ph-quotes input-icon"></i>
                <input
                  type="text"
                  id="pria_nama_panggilan"
                  name="pria_nama_panggilan"
                  class="form-input"
                  placeholder="contoh: Romeo"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="pria_ayah">Nama Ayah</label>
              <div class="input-wrapper">
                <i class="ph ph-user-list input-icon"></i>
                <input
                  type="text"
                  id="pria_ayah"
                  name="pria_ayah"
                  class="form-input"
                  placeholder="contoh: Bapak Fulan"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="pria_ibu">Nama Ibu</label>
              <div class="input-wrapper">
                <i class="ph ph-user-list input-icon"></i>
                <input
                  type="text"
                  id="pria_ibu"
                  name="pria_ibu"
                  class="form-input"
                  placeholder="contoh: Ibu Fulanah"
                  required
                />
              </div>
            </div>
          </div>
        </section>

        <!-- Block 3: Data Mempelai Wanita -->
        <section
          class="form-section reveal-on-scroll"
          id="mempelai-wanita-section"
          style="transition-delay: 300ms"
        >
          <div class="section-header">
            <h2 class="section-title">Data Mempelai Wanita</h2>
          </div>
          <div class="section-body">
            <div class="input-group">
              <label for="wanita_nama_lengkap">Nama Lengkap</label>
              <div class="input-wrapper">
                <i class="ph ph-user input-icon"></i>
                <input
                  type="text"
                  id="wanita_nama_lengkap"
                  name="wanita_nama_lengkap"
                  class="form-input"
                  placeholder="contoh: Juliet Capulet"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="wanita_nama_panggilan">Nama Panggilan</label>
              <div class="input-wrapper">
                <i class="ph ph-quotes input-icon"></i>
                <input
                  type="text"
                  id="wanita_nama_panggilan"
                  name="wanita_nama_panggilan"
                  class="form-input"
                  placeholder="contoh: Juliet"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="wanita_ayah">Nama Ayah</label>
              <div class="input-wrapper">
                <i class="ph ph-user-list input-icon"></i>
                <input
                  type="text"
                  id="wanita_ayah"
                  name="wanita_ayah"
                  class="form-input"
                  placeholder="contoh: Bapak Fulan"
                  required
                />
              </div>
            </div>

            <div class="input-group">
              <label for="wanita_ibu">Nama Ibu</label>
              <div class="input-wrapper">
                <i class="ph ph-user-list input-icon"></i>
                <input
                  type="text"
                  id="wanita_ibu"
                  name="wanita_ibu"
                  class="form-input"
                  placeholder="contoh: Ibu Fulanah"
                  required
                />
              </div>
            </div>
          </div>
        </section>

        <!-- Block 4: Acara Pernikahan (Events) -->
        <section
          class="form-section reveal-on-scroll"
          id="events-section"
          style="transition-delay: 400ms"
        >
          <div class="section-header" style="display: block;">
            <h2 class="section-title" style="margin-bottom: 4px;">Daftar Acara</h2>
            <p style="font-size: 13px; color: var(--form-text-muted); margin: 0;">Centang acara yang ingin disertakan di undangan Anda.</p>
          </div>

          <div class="section-body">
            
            <!-- Event 1: Akad Nikah -->
            <div class="dynamic-item" style="border: 1px solid var(--form-border); padding: 20px; border-radius: 8px; margin-bottom: 24px;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 class="item-title" style="margin: 0; font-size: 16px;">Akad Nikah</h3>
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; font-weight: 600;">
                  <input type="checkbox" id="enable_akad" checked onchange="toggleEventInputs('akad', this.checked)" style="width: 16px; height: 16px;">
                  Sertakan
                </label>
              </div>
              <div id="akad_inputs">
                <input type="hidden" name="wedding_events[0][tipe_acara]" value="Akad Nikah" />
                <div class="grid-2">
                  <div class="input-group">
                    <label>Tanggal</label>
                    <div class="input-wrapper">
                      <i class="ph ph-calendar input-icon"></i>
                      <input type="text" name="wedding_events[0][tanggal]" class="form-input" placeholder="contoh: 25 Desember 2026" required />
                    </div>
                  </div>
                  <div class="input-group">
                    <label>Waktu</label>
                    <div class="input-wrapper">
                      <i class="ph ph-clock input-icon"></i>
                      <input type="text" name="wedding_events[0][waktu]" class="form-input" placeholder="contoh: 08:00 - 10:00 WIB" required />
                    </div>
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Nama Lokasi</label>
                  <div class="input-wrapper">
                    <i class="ph ph-buildings input-icon"></i>
                    <input type="text" name="wedding_events[0][lokasi_nama]" class="form-input" placeholder="contoh: Masjid Agung" required />
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Alamat Lengkap</label>
                  <div class="input-wrapper">
                    <i class="ph ph-map-pin input-icon"></i>
                    <input type="text" name="wedding_events[0][lokasi_alamat]" class="form-input" placeholder="contoh: Jl. Raya..." required />
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Link Google Maps</label>
                  <div class="input-wrapper">
                    <i class="ph ph-link input-icon"></i>
                    <input type="url" name="wedding_events[0][maps_url]" class="form-input" placeholder="https://goo.gl/maps/..." required />
                  </div>
                </div>
              </div>
            </div>

            <!-- Event 2: Resepsi -->
            <div class="dynamic-item" style="border: 1px solid var(--form-border); padding: 20px; border-radius: 8px;">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
                <h3 class="item-title" style="margin: 0; font-size: 16px;">Resepsi</h3>
                <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px; font-weight: 600;">
                  <input type="checkbox" id="enable_resepsi" checked onchange="toggleEventInputs('resepsi', this.checked)" style="width: 16px; height: 16px;">
                  Sertakan
                </label>
              </div>
              <div id="resepsi_inputs">
                <input type="hidden" name="wedding_events[1][tipe_acara]" value="Resepsi" />
                <div class="grid-2">
                  <div class="input-group">
                    <label>Tanggal</label>
                    <div class="input-wrapper">
                      <i class="ph ph-calendar input-icon"></i>
                      <input type="text" name="wedding_events[1][tanggal]" class="form-input" placeholder="contoh: 26 Desember 2026" required />
                    </div>
                  </div>
                  <div class="input-group">
                    <label>Waktu</label>
                    <div class="input-wrapper">
                      <i class="ph ph-clock input-icon"></i>
                      <input type="text" name="wedding_events[1][waktu]" class="form-input" placeholder="contoh: 11:00 - 14:00 WIB" required />
                    </div>
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Nama Lokasi</label>
                  <div class="input-wrapper">
                    <i class="ph ph-buildings input-icon"></i>
                    <input type="text" name="wedding_events[1][lokasi_nama]" class="form-input" placeholder="contoh: Gedung Serbaguna" required />
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Alamat Lengkap</label>
                  <div class="input-wrapper">
                    <i class="ph ph-map-pin input-icon"></i>
                    <input type="text" name="wedding_events[1][lokasi_alamat]" class="form-input" placeholder="contoh: Jl. Melati..." required />
                  </div>
                </div>
                <div class="input-group" style="margin-top: 16px;">
                  <label>Link Google Maps</label>
                  <div class="input-wrapper">
                    <i class="ph ph-link input-icon"></i>
                    <input type="url" name="wedding_events[1][maps_url]" class="form-input" placeholder="https://goo.gl/maps/..." required />
                  </div>
                </div>
              </div>
            </div>

            <script>
              function toggleEventInputs(eventId, isEnabled) {
                const container = document.getElementById(`${eventId}_inputs`);
                const inputs = container.querySelectorAll('input');
                inputs.forEach(input => {
                  if (input.type !== 'hidden') {
                    input.disabled = !isEnabled;
                    // Jaga required status
                    if (isEnabled) {
                      input.required = true;
                    } else {
                      input.required = false;
                    }
                  }
                });
                container.style.opacity = isEnabled ? '1' : '0.5';
                container.style.pointerEvents = isEnabled ? 'auto' : 'none';
              }
            </script>

          </div>
        </section>

        <!-- Block 5: Galeri Foto -->
        <section
          class="form-section reveal-on-scroll"
          id="gallery-section"
          style="transition-delay: 500ms"
        >
          <div class="section-header">
            <h2 class="section-title">Galeri Foto</h2>
            <button type="button" class="btn-add-item" id="btn-add-gallery">
              <i class="ph ph-plus"></i> Tambah
            </button>
          </div>

          <div class="section-body" id="gallery-container">
            <!-- Gallery items will be injected here via JS -->
          </div>
        </section>

        <div class="form-actions reveal-on-scroll" style="transition-delay: 600ms">
          <button type="submit" class="btn-submit" id="btn-submit-form">
            Simpan Data Undangan
          </button>
        </div>
      </form>
    </div>

    <!-- Success Modal -->
    <div id="success-modal" class="modal-overlay">
      <div class="modal-content">
        <i class="ph ph-check-circle modal-icon"></i>
        <h3 class="modal-title">Berhasil Tersimpan!</h3>
        <p class="modal-desc">Data undangan Anda telah diperbarui. Berikut adalah tautan undangan yang siap Anda sebarkan ke tamu spesial Anda.</p>
        
        <div class="modal-link-box">
          <span class="modal-link-text" id="modal-link-text">http://localhost:3000/invitation/slug</span>
          <button class="btn-copy" id="btn-copy-link" aria-label="Salin Tautan">
            <i class="ph ph-copy"></i>
          </button>
        </div>
        
        <button class="btn-close-modal" id="btn-close-modal">Salin & Tutup</button>
      </div>
    </div>

    <!-- Toast Notification -->
    <div id="toast-notification" class="toast">Data berhasil disimpan!</div>

    <script>
      window.INITIAL_DATA = <%- typeof undangan !== 'undefined' ? JSON.stringify(undangan) : 'null' %>;
    </script>

    <script src="/javascript/main-website.js"></script>
    <script src="/javascript/form.js"></script>
  </body>
</html>
