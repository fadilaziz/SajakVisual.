<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cek Transaksi - Sajak Visual</title>

    <!-- Favicon-->
    <link rel="icon" type="image/webp" href="/img/favicon.webp" />

    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Custom Styles -->
    <link rel="stylesheet" href="/css/main-website.css" />
    <link rel="stylesheet" href="/css/transaksi.css" />
  </head>
  <body class="loading-state">
    <div class="app-container">
      <!-- Header -->
      <header class="header reveal-on-scroll">
        <div class="greeting">
          <div class="hide-on-load" style="display: contents">
            <img src="/img/logo_sajakvisual.webp" alt="Sajak Visual" class="brand-logo" />
            <p>Layanan Undangan Digital</p>
          </div>
          <div class="show-on-load" style="width: 100%">
            <div
              class="skeleton"
              style="width: 120px; height: 20px; margin-bottom: 6px; border-radius: 4px"
            ></div>
            <div
              class="skeleton"
              style="width: 160px; height: 14px; margin-bottom: 0; border-radius: 4px"
            ></div>
          </div>
        </div>
        <div class="hide-on-load" style="display: contents">
          <button class="theme-toggle-btn" aria-label="Toggle Dark Mode" id="theme-toggle">
            <i class="ph ph-moon"></i>
          </button>
        </div>
        <div class="show-on-load">
          <div
            class="skeleton"
            style="width: 40px; height: 40px; border-radius: var(--radius-xl)"
          ></div>
        </div>
      </header>

      <!-- Transaction Tracker Content -->
      <main
        class="transaction-container reveal-on-scroll"
        style="transition-delay: 100ms; padding-bottom: 120px"
      >
        <div class="hide-on-load" style="display: contents">
          <div class="transaction-hero">
            <h2>Cek Transaksi Kamu</h2>
            <p>Masukkan nomor invoice yang kamu dapatkan setelah melakukan Pemesanan.</p>
          </div>

          <form class="transaction-form" id="form-cek-transaksi">
            <div class="input-group">
              <label for="invoice-input">Nomor Invoice</label>
              <div class="input-wrapper">
                <i class="ph ph-magnifying-glass input-icon"></i>
                <input
                  type="text"
                  id="invoice-input"
                  class="form-input"
                  placeholder="SJV-20261406-123456"
                  autocomplete="off"
                  required
                />
              </div>
            </div>
            <button
              type="submit"
              class="btn-detail btn-submit-transaksi"
              style="position: relative"
            >
              Cek Sekarang
            </button>
            <div id="loading-overlay" class="loading-overlay">
              <div class="spinner"></div>
            </div>
          </form>

          <!-- Transaction Result Container -->
          <div id="transaction-result" class="transaction-result-container">
            <div class="res-header" style="align-items: flex-start">
              <div style="display: flex; gap: 12px; align-items: center">
                <img
                  id="res-template-image"
                  src=""
                  alt="Template"
                  onerror="this.style.display = 'none'"
                  style="
                    width: 50px;
                    height: 50px;
                    object-fit: cover;
                    border-radius: 8px;
                    border: 1px solid var(--border);
                    display: none;
                  "
                />
                <div>
                  <h3 id="res-template-name" class="res-title">Nama Template</h3>
                  <p id="res-category" class="res-subtitle">Kategori</p>
                </div>
              </div>
              <span id="res-status" class="badge">STATUS</span>
            </div>

            <div class="res-details">
              <div class="res-row">
                <span class="res-label">No Invoice</span>
                <span id="res-invoice" class="res-value">-</span>
              </div>
              <div class="res-row">
                <span class="res-label">Tanggal</span>
                <span id="res-date" class="res-value">-</span>
              </div>
              <div class="res-row">
                <span class="res-label">Nama Pemesan</span>
                <span id="res-name" class="res-value">-</span>
              </div>
              <div class="res-row">
                <span class="res-label">Email</span>
                <span id="res-email" class="res-value">-</span>
              </div>
              <div class="res-row">
                <span class="res-label">No WhatsApp</span>
                <span id="res-wa" class="res-value">-</span>
              </div>
              <div class="res-row">
                <span class="res-label">Produk</span>
                <span id="res-product" class="res-value">-</span>
              </div>
              <div
                class="res-row"
                style="margin-top: 8px; border-top: 1px dashed var(--border); padding-top: 16px"
              >
                <span class="res-label">Total Harga</span>
                <span id="res-amount" class="res-value amount">-</span>
              </div>
            </div>

            <div id="res-actions" class="res-actions">
              <!-- Action buttons injected via JS -->
            </div>
          </div>
        </div>

        <div class="show-on-load" style="width: 100%; padding: 0 24px">
          <div
            style="
              display: flex;
              flex-direction: column;
              align-items: center;
              text-align: center;
              margin-top: 32px;
              margin-bottom: 32px;
            "
          >
            <div
              class="skeleton"
              style="width: 64px; height: 64px; border-radius: 50%; margin-bottom: 24px"
            ></div>
            <div
              class="skeleton"
              style="width: 200px; height: 28px; border-radius: 4px; margin-bottom: 12px"
            ></div>
            <div class="skeleton" style="width: 280px; height: 16px; border-radius: 4px"></div>
          </div>
          <div
            style="
              background-color: var(--card);
              border: 1px solid var(--border);
              border-radius: var(--radius-xl);
              padding: 24px;
              box-shadow: var(--shadow-sm);
            "
          >
            <div
              class="skeleton"
              style="width: 100px; height: 16px; border-radius: 4px; margin-bottom: 8px"
            ></div>
            <div
              class="skeleton"
              style="
                width: 100%;
                height: 50px;
                border-radius: var(--radius-md);
                margin-bottom: 24px;
              "
            ></div>
            <div
              class="skeleton"
              style="width: 100%; height: 44px; border-radius: var(--radius-md)"
            ></div>
          </div>
        </div>
      </main>
    </div>

    <!-- Bottom Navigation -->
    <nav class="bottom-nav" id="bottom-nav">
      <a href="/" class="nav-item">
        <i class="ph ph-house"></i>
        <span>Utama</span>
      </a>
      <a href="/transaksi" class="nav-item active">
        <i class="ph ph-receipt"></i>
        <span>Transaksi</span>
      </a>
      <a href="/bantuan" class="nav-item">
        <i class="ph ph-info"></i>
        <span>Bantuan</span>
      </a>
    </nav>

    <script src="/javascript/main-website.js"></script>
    <script src="/javascript/transaksi.js"></script>
    <script>
      console.log(`
