<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Daftar Pesanan - SajakVisual.</title>
    <link rel="icon" type="image/webp" href="/img/favicon.webp" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link rel="stylesheet" href="/css/dashboard.css" />
    <link rel="stylesheet" href="/css/pesanan.css" />
    <link rel="stylesheet" href="/css/notification.css" />
  </head>
  <body>
    <div class="dashboard-layout">
      <!-- Sidebar -->
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <img src="/img/Just Logo White.webp" alt="SajakVisual" class="sidebar-logo-img" />
          <span class="sidebar-title">SajakVisual.</span>
        </div>
        <nav class="sidebar-nav">
          <a href="/admin/dashboard" class="nav-item">
            <i class="ph ph-squares-four"></i>
            <span class="nav-text">Dashboard</span>
          </a>
          <a href="/admin/pesanan" class="nav-item active">
            <i class="ph ph-shopping-cart"></i>
            <span class="nav-text">Pesanan</span>
          <!-- </a>
          <a href="#" class="nav-item">
            <i class="ph ph-users"></i>
            <span class="nav-text">Pelanggan</span>
          </a>
          <a href="#" class="nav-item">
            <i class="ph ph-gear"></i>
            <span class="nav-text">Pengaturan</span>
          </a> -->
        </nav>
        <div class="sidebar-footer">
          <a class="nav-item logout" id="logout">
            <i class="ph ph-sign-out"></i>
            <span class="nav-text">Keluar</span>
          </a>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="main-wrapper">
        <!-- Navbar -->
        <header class="navbar">
          <div class="navbar-left">
            <h2>Daftar Pesanan</h2>
          </div>
          <div class="navbar-right">
            <button id="theme-toggle" class="theme-toggle" aria-label="Toggle Theme">
              <i class="ph ph-moon"></i>
            </button>
            <div class="admin-profile">
              <div class="avatar">
                <i class="ph ph-user"></i>
              </div>
            </div>
          </div>
        </header>

        <!-- Pesanan Content -->
        <div class="content">
          <div class="content-header">
            <h1>Kelola Pesanan Pelanggan</h1>
            <p>
              Pantau dan kelola seluruh transaksi dan pesanan yang masuk ke sistem SajakVisual secara real-time.
            </p>
          </div>

          <!-- History Table -->
          <div class="table-container fade-in-up">
            <div class="table-header">
              <div class="table-actions">
                <div class="search-box">
                  <i class="ph ph-magnifying-glass"></i>
                  <input type="text" id="search-input" placeholder="Cari invoice atau nama..." />
                </div>
                <select id="status-filter" class="filter-select">
                  <option value="ALL">Semua Status</option>
                  <option value="SUCCESS">Berhasil</option>
                  <option value="PENDING">Pending</option>
                  <option value="FAILED">Gagal</option>
                </select>
              </div>
            </div>
            <div class="table-wrapper">
              <table class="data-table" id="orders-table">
                <thead>
                  <tr>
                    <th>Invoice ID</th>
                    <th>Nama Pelanggan</th>
                    <th>Tanggal</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th class="action-th">Aksi</th>
                  </tr>
                </thead>
                <tbody id="orders-table-body">
                  <!-- Data will be populated here via JS -->
                  <tr>
                    <td colspan="6" class="empty-state">Memuat data pesanan...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </main>
    </div>

    <!-- Modal Detail Pesanan -->
    <div id="detail-modal" class="modal-overlay">
      <div class="modal-content">
        <div class="modal-header">
          <h3>Detail Pesanan</h3>
          <button class="close-modal" id="close-modal"><i class="ph ph-x"></i></button>
        </div>
        <div class="modal-body" id="modal-body-content">
          <!-- Content populated via JS -->
        </div>
      </div>
    </div>

    <!-- Import Javascript -->
    <script src="/javascript/notification.js"></script>
    <script src="/javascript/pesanan.js"></script>
  </body>
</html>
