<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Undangan Pernikahan - <%= data.mempelai_pria.nama_panggilan %> & <%= data.mempelai_wanita.nama_panggilan %></title>
    
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    
    <!-- CSS -->
    <link rel="stylesheet" href="/css/modern_invitation.css">
</head>
<body style="overflow: hidden;">

    <!-- Audio Element -->
    <audio id="bg-audio" loop preload="auto">
        <source src="<%= data.bg_music %>" type="audio/mpeg">
    </audio>

    <!-- Music Control -->
    <button id="music-control" class="paused" aria-label="Toggle Music">
        <i class="ph ph-play"></i>
    </button>

    <!-- Cover Overlay (Open Invitation) -->
    <div id="cover-overlay">
        <div class="cover-names">
            <%= data.mempelai_pria.nama_panggilan %><br>&<br><%= data.mempelai_wanita.nama_panggilan %>
        </div>
        <button id="btn-open-invitation" class="btn-open">
            Buka Undangan
        </button>
    </div>

    <!-- Main Container -->
    <div class="inv-container">
        
        <!-- Hero Section -->
        <section class="hero">
            <div class="hero-top-date reveal">
                <span>08</span>
                <span>JULI</span>
                <span>2026</span>
            </div>
            
            <h1 class="hero-name reveal"><%= data.mempelai_pria.nama_panggilan %></h1>
            
            <div class="hero-img-container reveal">
                <img src="<%= data.foto_cover %>" alt="Cover Photo" class="hero-img">
            </div>
            
            <h1 class="hero-name reveal"><%= data.mempelai_wanita.nama_panggilan %></h1>
            
            <div class="hero-heart reveal">
                <i class="ph-fill ph-heart"></i>
            </div>
            
            <div class="hero-intro reveal">
                <p>Dengan memohon rahmat dan ridho Allah SWT, kami bermaksud mengundang Bapak/Ibu/Saudara/i untuk hadir pada acara pernikahan kami.</p>
                <br>
                <p>Putra dari <%= data.mempelai_pria.ayah %> & <%= data.mempelai_pria.ibu %></p>
                <p style="margin: 5px 0;">dengan</p>
                <p>Putri dari <%= data.mempelai_wanita.ayah %> & <%= data.mempelai_wanita.ibu %></p>
            </div>
        </section>

        <div class="divider"></div>

        <!-- Calendar Section -->
        <section class="calendar-section">
            <h2 class="calendar-title reveal">Juli</h2>
            
            <div class="calendar-grid reveal">
                <div class="cal-header">SN</div>
                <div class="cal-header">SL</div>
                <div class="cal-header">RB</div>
                <div class="cal-header">KM</div>
                <div class="cal-header">JM</div>
                <div class="cal-header">SB</div>
                <div class="cal-header">MG</div>
                
                <!-- Static layout matching July 2026 for demonstration -->
                <div class="cal-day"></div>
                <div class="cal-day"></div>
                <div class="cal-day">1</div>
                <div class="cal-day">2</div>
                <div class="cal-day">3</div>
                <div class="cal-day">4</div>
                <div class="cal-day">5</div>
                
                <div class="cal-day">6</div>
                <div class="cal-day">7</div>
                <div class="cal-day">8</div>
                <div class="cal-day">9</div>
                <div class="cal-day">10</div>
                <div class="cal-day">11</div>
                <div class="cal-day cal-highlight">
                    12
                    <i class="ph ph-heart cal-heart-outline"></i>
                </div>
                
                <div class="cal-day">13</div>
                <div class="cal-day">14</div>
                <div class="cal-day">15</div>
                <div class="cal-day">16</div>
                <div class="cal-day">17</div>
                <div class="cal-day">18</div>
                <div class="cal-day">19</div>
            </div>
        </section>

        <div class="divider"></div>

        <!-- RSVP Section -->
        <section class="rsvp-section reveal">
            <h2 class="rsvp-title-1">Konfirmasi</h2>
            <h2 class="rsvp-title-2">Kehadiran</h2>
            
            <p class="rsvp-text">Kehadiran Anda sangat berarti bagi kami. Kami mohon untuk mengkonfirmasi kehadiran Anda sebelum tanggal 1 Juli 2026.</p>
        </section>
        
        <a href="#" class="btn-rsvp">Konfirmasi Kehadiran</a>

        <!-- Program Section -->
        <section class="program-section">
            <h2 class="program-title-1 reveal">Rangkaian</h2>
            <h2 class="program-title-2 reveal">Acara</h2>
            
            <div class="timeline">
                <!-- Akad Item -->
                <div class="timeline-item reveal">
                    <div class="timeline-time"><%= data.acara.akad.waktu.split(' - ')[0] %></div>
                    <div class="timeline-content">
                        <h3 class="timeline-title">Akad Nikah</h3>
                        <p class="timeline-desc">
                            Momen paling sakral dalam hidup kami.<br>
                            <%= data.acara.akad.lokasi_nama %>
                        </p>
                        <a href="<%= data.acara.akad.maps_url %>" target="_blank" class="btn-maps-small">Lihat Peta</a>
                    </div>
                </div>

                <!-- Resepsi Item -->
                <div class="timeline-item reveal">
                    <div class="timeline-time"><%= data.acara.resepsi.waktu.split(' - ')[0] %></div>
                    <div class="timeline-content">
                        <h3 class="timeline-title">Resepsi</h3>
                        <p class="timeline-desc">
                            Perayaan cinta dan kebahagiaan bersama keluarga & sahabat.<br>
                            <%= data.acara.resepsi.lokasi_nama %>
                        </p>
                        <a href="<%= data.acara.resepsi.maps_url %>" target="_blank" class="btn-maps-small">Lihat Peta</a>
                    </div>
                </div>
            </div>
        </section>

        <div class="divider"></div>

        <!-- Gallery Section -->
        <section class="gallery-section">
            <div class="gallery-grid-new">
                <% data.galeri_foto.forEach((foto, index) => { %>
                    <div class="reveal" style="transition-delay: <%= index * 100 %>ms;">
                        <img src="<%= foto %>" alt="Gallery Photo <%= index + 1 %>" class="gallery-img-new">
                    </div>
                <% }); %>
            </div>
        </section>

        <footer style="text-align: center; padding: 2rem; border-top: 1px solid var(--inv-line); font-size: 0.7rem; color: #999; text-transform: uppercase; letter-spacing: 2px;">
            <p>Created with love by Sajak Visual</p>
        </footer>
    </div>

    <!-- JS -->
    <script src="/javascript/modern_invitation.js"></script>
</body>
</html>
